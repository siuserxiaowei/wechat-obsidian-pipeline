<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ chat_name }} · {{ date }} · 群日报</title>
<style>
  /* === 苹果中文字体栈 + 等宽数字 === */
  :root {
    --bg: #FAFAFA;
    --card: #FFFFFF;
    --bubble: #F2F2F2;
    --text: #1A1A1A;
    --muted: #888888;
    --line: #E8E8E8;
    --accent: #07C160;       /* 微信绿 */
    --accent-soft: #E6F7EE;
    --warn: #FA5151;
    --gold: #FFD700;
    --silver: #C0C0C0;
    --bronze: #CD7F32;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
    width: 430px;
  }
  .page { padding: 0 16px 32px; }

  /* === 头部 === */
  .header {
    text-align: center;
    padding: 28px 0 18px;
  }
  .header .dragon { font-size: 44px; line-height: 1; }
  .header h1 {
    margin: 8px 0 4px;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .header .sub {
    font-size: 12px;
    color: var(--muted);
  }
  .header .chat-name {
    margin-top: 6px;
    font-size: 13px;
    color: var(--accent);
    font-weight: 600;
  }

  /* === 段落标题 === */
  .section-title {
    font-size: 16px;
    font-weight: 700;
    margin: 22px 0 10px;
    padding-left: 4px;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .section-title .emoji { font-size: 18px; }
  .section-title .sub {
    font-size: 11px;
    color: var(--muted);
    font-weight: 400;
    margin-left: 6px;
  }

  /* === 通用卡片 === */
  .card {
    background: var(--card);
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 10px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }

  /* === 快捷事件: 金句列表 === */
  .quotes .row {
    display: flex;
    gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid var(--line);
  }
  .quotes .row:last-child { border-bottom: none; }
  .quotes .who {
    flex: 0 0 auto;
    min-width: 64px;
    font-weight: 600;
    color: var(--accent);
    font-size: 13px;
  }
  .quotes .quote {
    flex: 1;
    font-size: 13px;
  }

  /* === 龙王榜 === */
  .ranking { display: flex; gap: 8px; }
  .ranking .seat {
    flex: 1;
    text-align: center;
    padding: 14px 6px 10px;
    background: var(--card);
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }
  .ranking .seat .medal { font-size: 28px; line-height: 1; }
  .ranking .seat .name {
    margin-top: 6px;
    font-size: 13px;
    font-weight: 700;
    word-break: break-all;
  }
  .ranking .seat .cnt {
    margin-top: 2px;
    font-size: 12px;
    color: var(--muted);
    font-feature-settings: "tnum";
  }
  .ranking .seat .common {
    margin-top: 6px;
    font-size: 10px;
    color: var(--muted);
    line-height: 1.4;
    word-break: break-all;
  }
  .seat.gold   { background: linear-gradient(180deg,#FFFAEC,#FFF); }
  .seat.silver { background: linear-gradient(180deg,#F4F4F8,#FFF); }
  .seat.bronze { background: linear-gradient(180deg,#FBF1E6,#FFF); }

  /* === 资源分享卡片(3 列) === */
  .resources .res-card {
    background: var(--card);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 10px 12px;
    margin-bottom: 8px;
  }
  .resources .meta {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .resources .title {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
    line-height: 1.4;
  }
  .resources .desc {
    font-size: 12px;
    color: #555;
    line-height: 1.5;
  }
  .resources .url {
    margin-top: 6px;
    font-size: 11px;
    color: var(--accent);
    word-break: break-all;
  }
  .resources .points {
    margin: 6px 0 0;
    padding-left: 18px;
    font-size: 11px;
    color: #666;
  }
  .resources .points li { margin: 2px 0; }

  /* === 故事章节(对话气泡) === */
  .story {
    background: var(--card);
    border-radius: 12px;
    padding: 14px 14px 12px;
    margin-bottom: 14px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }
  .story-head {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px dashed var(--line);
  }
  .story-head .emoji { font-size: 18px; }
  .story-head .title {
    font-size: 15px;
    font-weight: 700;
  }
  .story-head .meta {
    margin-left: auto;
    font-size: 11px;
    color: var(--muted);
  }
  .bubbles { margin: 0 0 10px; }
  .bubble {
    margin: 7px 0;
  }
  .bubble .who {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 2px;
  }
  .bubble .who .time {
    margin-left: 6px;
    color: #BBB;
    font-feature-settings: "tnum";
  }
  .bubble .body {
    background: var(--bubble);
    border-radius: 4px 14px 14px 14px;
    padding: 8px 12px;
    font-size: 13px;
    line-height: 1.55;
    word-break: break-word;
  }
  .commentary {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--accent-soft);
    border-radius: 8px;
    font-size: 12px;
    color: #1F5F3D;
    line-height: 1.6;
    border-left: 3px solid var(--accent);
  }
  .commentary::before {
    content: "✏️ 毒舌点评 ";
    font-weight: 700;
    margin-right: 4px;
  }

  /* === 复读/集体回声 === */
  .echo {
    background: var(--card);
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 14px;
    text-align: center;
  }
  .echo .quote {
    font-size: 17px;
    font-weight: 700;
    margin: 8px 0 12px;
    color: var(--accent);
  }
  .echo .voicers {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* === 今日总结(颁奖) === */
  .awards { margin-top: 6px; }
  .awards .row {
    display: flex;
    align-items: center;
    padding: 12px 14px;
    background: var(--card);
    border-radius: 10px;
    margin-bottom: 8px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }
  .awards .label {
    flex: 0 0 70px;
    font-size: 12px;
    color: var(--muted);
  }
  .awards .winner {
    flex: 0 0 auto;
    font-weight: 700;
    color: var(--accent);
    font-size: 14px;
    margin-right: 10px;
  }
  .awards .reason {
    flex: 1;
    font-size: 12px;
    color: #555;
    line-height: 1.5;
  }

  /* === 词云(简化:一行 chip) === */
  .cloud {
    background: var(--card);
    border-radius: 10px;
    padding: 12px;
    margin-bottom: 14px;
  }
  .cloud-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 6px;
  }
  .cloud-chips .chip {
    padding: 2px 8px;
    background: var(--bubble);
    border-radius: 999px;
    font-size: 11px;
    color: #555;
  }
  .cloud-chips .chip.hot { background: #FFE4E6; color: var(--warn); font-weight: 700; }

  /* === 页脚 === */
  .footer {
    text-align: center;
    margin-top: 28px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    color: var(--muted);
    line-height: 1.7;
  }
</style>
</head>
<body>
<div class="page">

  {# === 头部 === #}
  <div class="header">
    <div class="dragon">{{ header_emoji or "🐉" }}</div>
    <h1>群日报</h1>
    <div class="sub">{{ date }} · 共 {{ total_count }} 条 · {{ active_users }} 人活跃</div>
    <div class="chat-name">{{ chat_name }}</div>
  </div>

  {# === 🔥 快捷事件 === #}
  {% if quick_quotes %}
  <div class="section-title"><span class="emoji">🔥</span><span>快捷事件</span><span class="sub">今天群里说了啥</span></div>
  <div class="card quotes">
    {% for q in quick_quotes %}
    <div class="row">
      <div class="who">{{ q.name }}</div>
      <div class="quote">{{ q.quote }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# === 🏆 龙王榜 === #}
  {% if ranking_top3 %}
  <div class="section-title"><span class="emoji">🏆</span><span>龙王榜</span><span class="sub">话痨 TOP 3</span></div>
  <div class="ranking">
    {% for r in ranking_top3 %}
    <div class="seat {{ ['gold','silver','bronze'][loop.index0] if loop.index0 < 3 else '' }}">
      <div class="medal">{{ r.medal or ['🥇','🥈','🥉'][loop.index0] }}</div>
      <div class="name">{{ r.name }}</div>
      <div class="cnt">{{ r.count }} 条</div>
      {% if r.common_words %}<div class="common">{{ r.common_words | join(' / ') }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# === 🔗 资源分享 === #}
  {% if resources %}
  <div class="section-title"><span class="emoji">🔗</span><span>资源分享</span><span class="sub">值得收藏</span></div>
  <div class="resources">
    {% for r in resources %}
    <div class="res-card">
      <div class="meta">{{ r.sharer }} · {{ r.time }} · <em>{{ r.type or '资源' }}</em></div>
      <div class="title">{{ r.title }}</div>
      {% if r.description %}<div class="desc">{{ r.description }}</div>{% endif %}
      {% if r.url %}<div class="url">{{ r.url }}</div>{% endif %}
      {% if r.key_points %}
      <ul class="points">
        {% for p in r.key_points %}<li>{{ p }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# === 主内容: 故事章节 === #}
  {% for s in story_sections %}
  <div class="story">
    <div class="story-head">
      <span class="emoji">{{ s.emoji or "💬" }}</span>
      <span class="title">{{ s.title }}</span>
      {% if s.time_range %}<span class="meta">{{ s.time_range }}</span>{% endif %}
    </div>
    <div class="bubbles">
      {% for m in s.messages %}
      <div class="bubble">
        <div class="who">{{ m.name }}{% if m.time %}<span class="time">{{ m.time }}</span>{% endif %}</div>
        <div class="body">{{ m.content }}</div>
      </div>
      {% endfor %}
    </div>
    {% if s.commentary %}
    <div class="commentary">{{ s.commentary }}</div>
    {% endif %}
  </div>
  {% endfor %}

  {# === 集体复读 (可选) === #}
  {% if echo_quote %}
  <div class="section-title"><span class="emoji">💪</span><span>群体复读</span></div>
  <div class="echo">
    <div class="quote">"{{ echo_quote.text }}"</div>
    <div class="voicers">{{ echo_quote.voicers | join(' · ') }}{% if echo_quote.count %} · 共 {{ echo_quote.count }} 人接力{% endif %}</div>
  </div>
  {% endif %}

  {# === 词云 chip === #}
  {% if word_cloud %}
  <div class="section-title"><span class="emoji">☁️</span><span>群里今天的关键词</span></div>
  <div class="cloud">
    <div class="cloud-chips">
      {% for w in word_cloud[:30] %}
      <span class="chip {% if w.count >= top_word_threshold %}hot{% endif %}">{{ w.text }}{% if w.count %} <small>·{{ w.count }}</small>{% endif %}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# === 📊 今日总结 (颁奖) === #}
  {% if daily_awards %}
  <div class="section-title"><span class="emoji">📊</span><span>今日总结</span><span class="sub">颁奖时刻</span></div>
  <div class="awards">
    {% for a in daily_awards %}
    <div class="row">
      <div class="label">{{ a.award }}</div>
      <div class="winner">{{ a.winner }}</div>
      <div class="reason">{{ a.reason or a.quote or "" }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="footer">
    生成于 {{ generated_at }} · 数据源: {{ source }}<br>
    by Claudian × Obsidian
  </div>
</div>
</body>
</html>
